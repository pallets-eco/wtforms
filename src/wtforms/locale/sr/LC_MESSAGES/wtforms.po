#: src/wtforms/validators.py:86
#, python-format
msgid "Invalid field name '%s'."
msgstr "Nevalidno ime polja '%s'."

#: src/wtforms/validators.py:99
#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Polje mora biti jednako %(other_name)s."

#: src/wtforms/validators.py:145
#, python-format
msgid "Field must be at least %(min)d character long."
msgid_plural "Field must be at least %(min)d characters long."
msgstr[0] "Polje mora imati najmanje %(min)d karakter."
msgstr[1] "Polje mora imati najmanje %(min)d karaktera."
msgstr[2] "Polje mora imati najmanje %(min)d karaktera."

#: src/wtforms/validators.py:151
#, python-format
msgid "Field cannot be longer than %(max)d character."
msgid_plural "Field cannot be longer than %(max)d characters."
msgstr[0] "Polje ne može biti duže od %(max)d karaktera."
msgstr[1] "Polje ne može biti duže od %(max)d karaktera."
msgstr[2] "Polje ne može biti duže od %(max)d karaktera."

#: src/wtforms/validators.py:157
#, python-format
msgid "Field must be exactly %(max)d character long."
msgid_plural "Field must be exactly %(max)d characters long."
msgstr[0] "Polje mora imati tačno %(max)d karakter."
msgstr[1] "Polje mora imati tačno %(max)d karaktera."
msgstr[2] "Polje mora imati tačno %(max)d karaktera."

#: src/wtforms/validators.py:163
#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Polje mora imati između %(min)d i %(max)d karaktera."

#: src/wtforms/validators.py:216
#, python-format
msgid "Number must be at least %(min)s."
msgstr "Broj mora biti najmanje %(min)s."

#: src/wtforms/validators.py:219
#, python-format
msgid "Number must be at most %(max)s."
msgstr "Broj ne može biti veći od %(max)s."

#: src/wtforms/validators.py:222
#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Broj mora biti između %(min)s i %(max)s."

#: src/wtforms/validators.py:293 src/wtforms/validators.py:323
msgid "This field is required."
msgstr "Ovo polje je obavezno."

#: src/wtforms/validators.py:358
msgid "Invalid input."
msgstr "Neispravan unos."

#: src/wtforms/validators.py:422
msgid "Invalid email address."
msgstr "Nevalidna adresa e-pošte."

#: src/wtforms/validators.py:460
msgid "Invalid IP address."
msgstr "Nevalidna IP adresa."

#: src/wtforms/validators.py:503
msgid "Invalid Mac address."
msgstr "Nevalidna Mac adresa."

#: src/wtforms/validators.py:540
msgid "Invalid URL."
msgstr "Nevalidna URL adresa."

#: src/wtforms/validators.py:561
msgid "Invalid UUID."
msgstr "Nevalidan UUID."

#: src/wtforms/validators.py:594
#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Nevalidna vrednost, mora biti jedna od: %(values)s."

#: src/wtforms/validators.py:629
#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Nevalidna vrednost, ne može biti bilo koja od: %(values)s."

#: src/wtforms/validators.py:698
msgid "This field cannot be edited."
msgstr "Ovo polje se ne može menjati."

#: src/wtforms/validators.py:714
msgid "This field is disabled and cannot have a value."
msgstr "Ovo polje je onemogućeno i ne može imati vrednost."

#: src/wtforms/csrf/core.py:96
msgid "Invalid CSRF Token."
msgstr "Neispravan CSRF token."

#: src/wtforms/csrf/session.py:63
msgid "CSRF token missing."
msgstr "CSRF token nedostaje."

#: src/wtforms/csrf/session.py:71
msgid "CSRF failed."
msgstr "CSRF provera je neuspešna."

#: src/wtforms/csrf/session.py:76
msgid "CSRF token expired."
msgstr "CSRF token je istekao."

#: src/wtforms/fields/choices.py:142
msgid "Invalid Choice: could not coerce."
msgstr "Neispravan izbor: nije moguće konvertovati."

#: src/wtforms/fields/choices.py:149 src/wtforms/fields/choices.py:203
msgid "Choices cannot be None."
msgstr "Izbori ne mogu biti prazni."

#: src/wtforms/fields/choices.py:155
msgid "Not a valid choice."
msgstr "Nije validan izbor."

#: src/wtforms/fields/choices.py:193
msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr "Neispravan izbor: jedan ili više unosa ne mogu biti konvertovani."

#: src/wtforms/fields/choices.py:214
#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgid_plural "'%(value)s' are not valid choices for this field."
msgstr[0] "'%(value)s' nije validan izbor za ovo polje."
msgstr[1] "'%(value)s' nisu validni izbori za ovo polje."
msgstr[2] "'%(value)s' nisu validni izbori za ovo polje."

#: src/wtforms/fields/datetime.py:51
msgid "Not a valid datetime value."
msgstr "Nije validna vrednost datuma i vremena."

#: src/wtforms/fields/datetime.py:77
msgid "Not a valid date value."
msgstr "Nije validna vrednost datuma."

#: src/wtforms/fields/datetime.py:103
msgid "Not a valid time value."
msgstr "Nije validna vrednost vremena."

#: src/wtforms/fields/datetime.py:148
msgid "Not a valid week value."
msgstr "Nije validna vrednost nedelje."

#: src/wtforms/fields/numeric.py:82 src/wtforms/fields/numeric.py:92
msgid "Not a valid integer value."
msgstr "Nije validna vrednost celog broja."

#: src/wtforms/fields/numeric.py:168
msgid "Not a valid decimal value."
msgstr "Nije validna vrednost decimalnog broja."

#: src/wtforms/fields/numeric.py:197
msgid "Not a valid float value."
msgstr "Nije validna vrednost broja sa pokretnim zarezom."
